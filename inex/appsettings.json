{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File", "Serilog.Sinks.Async", "Serilog.Formatting.Compact", "Serilog.Enrichers.Process", "Serilog.Enrichers.Thread", "Serilog.Enrichers.Environment" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext", "WithProcessId", "WithThreadId", "WithMachineName" ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
      },
      {
        "Name": "Async",
        "Args": {
          "blockWhenFull": true,
          "configure": [
            {
              "Name": "File",
              "Args": {
                "path": "logs/inex-.log",
                "formatter": "Serilog.Formatting.Compact.CompactJsonFormatter, Serilog.Formatting.Compact",
                "rollingInterval": "Day",
                "retainedFileCountLimit": 30
              }
            }
          ]
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "InExConnection": ""
  },
  "ExchangeApiSettings": {
    "BaseUrl": "https://api.currencyapi.com/v3/",
    "ApiKey": ""
  },
  "FrankfurterApiSettings": {
    "BaseUrl": "https://api.frankfurter.dev/"
  }
}
